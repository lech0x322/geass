# ── Primary persistence — Neon Postgres ──────────────────────────────
# App data (profiles, marketplace, community, KOL feed, AI engine state)
# is stored here via the KV layer in src/lib/server/kv.ts.
# Pooled connection string from the Neon dashboard.
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require
# Optional direct (non-pooled) connection for migrations/long transactions.
DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require

# ── Legacy (optional) — Upstash Redis ────────────────────────────────
# No longer required; kept only for rollback. Leave unset to use Postgres.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
